{
  "routes": [
    {
      "route": "/id/*",
      "rewrite": "/api/id/*"
    },
    {
      "route": "/vocab/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "route": "/.well-known/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/vocab/*", "/.well-known/*", "/id/*"]
  },
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, OPTIONS"
  }
}